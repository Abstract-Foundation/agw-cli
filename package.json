{
  "name": "agw-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace root for the AGW agent-first CLI and companion app",
  "license": "MIT",
  "author": "Abstract Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abstract-Foundation/agw-mcp.git"
  },
  "homepage": "https://github.com/Abstract-Foundation/agw-mcp#readme",
  "bugs": {
    "url": "https://github.com/Abstract-Foundation/agw-mcp/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm --dir packages/agw-cli build && pnpm --dir app build",
    "dev": "pnpm --dir packages/agw-cli dev",
    "test": "jest",
    "test:e2e": "AGW_E2E_ENABLED=1 jest --runInBand test/e2e",
    "check-types": "tsc -p tsconfig.json --noEmit && pnpm --dir packages/agw-core check-types && pnpm --dir packages/agw-cli check-types && pnpm --dir app check-types",
    "lint": "eslint test packages --ext .ts",
    "prettier": "prettier --write \"packages/**/*.ts\" \"test/**/*.ts\""
  },
  "devDependencies": {
    "@abstract-foundation/agw-client": "1.10.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "open": "^10.1.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "viem": "^2.46.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "10.2.1",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "express-rate-limit": ">=8.2.2",
      "socket.io-parser": ">=4.2.6"
    }
  }
}
