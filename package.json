{
  "name": "agw-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Local MCP server for Abstract Global Wallet (AGW) session-key workflows",
  "type": "module",
  "bin": {
    "agw-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prettier": "prettier --write \"src/**/*.ts\"",
    "loop": "bash scripts/agent-loop.sh",
    "loop:once": "bash scripts/agent-loop.sh --once",
    "loop:dry": "bash scripts/agent-loop.sh --dry-run --once",
    "eval:nightly": "bash scripts/eval-nightly.sh"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "latest",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
