{
  "name": "@abstract-foundation/agw-mcp",
  "version": "0.1.0-beta.3",
  "description": "MCP server for Abstract Global Wallet session-key workflows",
  "license": "MIT",
  "author": "Abstract Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abstract-Foundation/agw-mcp.git"
  },
  "homepage": "https://github.com/Abstract-Foundation/agw-mcp#readme",
  "bugs": {
    "url": "https://github.com/Abstract-Foundation/agw-mcp/issues"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "agw",
    "abstract-global-wallet",
    "session-key",
    "wallet",
    "ethereum",
    "cli"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "bin": {
    "agw-mcp": "./dist/index.mjs"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.mjs",
    "prepublishOnly": "pnpm check-types && pnpm lint && pnpm test && pnpm build",
    "test": "jest",
    "test:e2e": "AGW_E2E_ENABLED=1 jest --runInBand test/e2e",
    "check-types": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "prettier": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "1.10.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "viem": "^2.46.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
